# OptionRank Lite — environment variables
#
# This app uses localStorage only — no environment variables are required
# to run the app locally or deploy to Vercel.
#
# Copy this file to .env.local if you add server-side features:
#   cp .env.example .env.local
#
# Never commit .env.local to git.

# Example (not used yet):
# NEXT_PUBLIC_APP_ENV=production
